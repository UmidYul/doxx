# Copy to .env; loaded by pydantic-settings (config/settings.py).
# Active contour: store spider -> scraper DB -> outbox -> publisher service -> RabbitMQ.

APP_ENV=development
LOG_LEVEL=INFO
# TRANSPORT_TYPE and CRM_* remain only for legacy migration tooling and are not used by the active scraper runtime.

# --- Legacy transport layer ---
# "disabled" for the active scraper contour | "crm_http" and "rabbitmq" for legacy-only tooling
TRANSPORT_TYPE=disabled
TRANSPORT_FAIL_FAST=true

# --- Legacy CRM HTTP transport (TRANSPORT_TYPE=crm_http) ---
CRM_BASE_URL=http://localhost:8000
# Локальный CRM: при ENABLE_LOCALHOST_BLOCK=true (по умолчанию) исходящие на localhost
# блокируются — для отладки на этой машине выставьте ENABLE_LOCALHOST_BLOCK=false
# или используйте: python scripts/crm_short_crawl.py --allow-localhost-crm
CRM_PARSER_KEY=changeme
CRM_SYNC_ENDPOINT=/api/parser/sync
CRM_SYNC_BATCH_ENDPOINT=/api/parser/sync/batch
CRM_CATALOG_FIND_ENDPOINT=/api/parser/catalog/find
CRM_HTTP_TIMEOUT_SECONDS=15.0
CRM_HTTP_RETRY_ATTEMPTS=3
CRM_HTTP_RETRY_BACKOFF_SECONDS=1.5
CRM_BATCH_SIZE=50

# Security baseline: secrets, redaction, optional HMAC (7A)
# X-Parser-Key stays mandatory for CRM; signing is optional unless hmac_required.
SECURITY_MODE=baseline
CRM_PARSER_KEY_FILE=
ENABLE_SECRET_FILE_FALLBACK=true
ENABLE_SECRET_REDACTION=true
ENABLE_SECURITY_STARTUP_VALIDATION=true
CRM_REQUEST_INTEGRITY_MODE=none
CRM_REQUEST_SIGNING_SECRET=
CRM_REQUEST_SIGNING_SECRET_FILE=
CRM_REQUEST_TIMESTAMP_HEADER=X-Request-Timestamp
CRM_REQUEST_NONCE_HEADER=X-Request-Nonce
CRM_REQUEST_SIGNATURE_HEADER=X-Request-Signature
CRM_REQUEST_SIGNATURE_ALGORITHM=hmac-sha256
MASK_SENSITIVE_HEADERS_IN_LOGS=true
MASK_SENSITIVE_FIELDS_IN_LOGS=true
SECURITY_FAIL_FAST_ON_INVALID_CONFIG=true

# Network safety / outbound controls (7B) — parser egress allowlists, redirects, proxy/browser guards
NETWORK_SECURITY_MODE=restricted
ENABLE_OUTBOUND_HOST_ALLOWLIST=true
ENABLE_PRIVATE_IP_BLOCK=true
ENABLE_LOCALHOST_BLOCK=true
ENABLE_FILE_SCHEME_BLOCK=true
ENABLE_UNSAFE_SCHEME_BLOCK=true
ENABLE_REDIRECT_HOST_VALIDATION=true
MAX_REDIRECT_HOPS=5
ENABLE_BROWSER_SAME_ORIGIN_GUARD=true
ENABLE_PROXY_HOST_VALIDATION=true
ENABLE_STORE_HOST_PINNING=true
ENABLE_CRM_HOST_PINNING=true
# Optional explicit allowlists (otherwise CRM host is derived from CRM_BASE_URL; store defaults in code).
# ALLOWED_STORE_HOSTS=shop.example.com,www.shop.example.com
# ALLOWED_CRM_HOSTS=crm.internal.example
# ALLOWED_PROXY_HOSTS=proxy.internal.example
BLOCK_PRIVATE_NETWORK_RANGES=true
BLOCK_METADATA_IPS=true

# Data minimization / operational hygiene (7C) — logging, exports, buffers, replay/support scope
ENABLE_DATA_MINIMIZATION=true
ENABLE_RUNTIME_RETENTION_LIMITS=true
ENABLE_SAFE_DIAGNOSTIC_EXPORTS=true
ENABLE_REPLAY_ABUSE_GUARDS=true
ENABLE_SUPPORT_SCOPE_RESTRICTIONS=true
TRACE_MAX_AGE_SECONDS=3600
BATCH_TRACE_MAX_AGE_SECONDS=3600
DIAGNOSTIC_SNAPSHOT_MAX_ITEMS=20
SUPPORT_EXPORT_MAX_ERRORS=20
SUPPORT_EXPORT_INCLUDE_RAW_SPECS=true
SUPPORT_EXPORT_INCLUDE_TYPED_SPECS=true
SUPPORT_EXPORT_INCLUDE_FIELD_CONFIDENCE=false
SUPPORT_EXPORT_INCLUDE_SUPPRESSED_FIELDS=false
SUPPORT_EXPORT_INCLUDE_RAW_HEADERS=false
SUPPORT_EXPORT_INCLUDE_FULL_URL_QUERY=false

# CRM batch / apply semantics (4B)
CRM_BATCH_REQUIRE_ITEM_RESULTS=true
CRM_BATCH_RETRY_ONLY_RETRYABLE_ITEMS=true
CRM_BATCH_REQUEUE_RETRYABLE_ITEMS=true
CRM_BATCH_MAX_RETRYABLE_ITEMS_PER_FLUSH=100
CRM_BATCH_STOP_ON_MALFORMED_RESPONSE=true
CRM_RUNTIME_SKIP_SAME_ENTITY_SAME_PAYLOAD=true
CRM_RUNTIME_SKIP_OLDER_PAYLOAD_IF_NEWER_SENT=false
PARSER_MARK_IGNORED_AS_APPLIED=true
PARSER_REQUEUE_RETRYABLE_ONCE=true
PARSER_MAX_EVENT_ATTEMPTS_PER_RUN=2

# Parser replay / idempotency / reconciliation (4C)
PARSER_REPLAY_MODE_DEFAULT=snapshot_upsert
PARSER_IDEMPOTENCY_SCOPE_DEFAULT=entity_payload
PARSER_ALLOW_SAFE_RESEND_PRODUCT_FOUND=true
PARSER_ALLOW_SAFE_RESEND_DELTA_EVENTS=false
PARSER_ENABLE_RESPONSE_LOSS_RECONCILIATION=true
PARSER_ENABLE_RUNTIME_RECONCILIATION=true
PARSER_ENABLE_CATALOG_FIND_RECONCILIATION=false
PARSER_RECONCILE_ON_MISSING_IDS=true
PARSER_RECONCILE_ON_AMBIGUOUS_RESULT=true
PARSER_RECONCILE_MAX_ATTEMPTS_PER_RUN=1
PARSER_INCLUDE_IDEMPOTENCY_KEY_IN_PAYLOAD=true
CRM_SEND_IDEMPOTENCY_KEY_HEADER=true

# --- Active RabbitMQ broker / publisher contour ---
BROKER_TYPE=rabbitmq
RABBITMQ_VHOST=moscraper
RABBITMQ_ADMIN_USER=moscraper_admin
RABBITMQ_ADMIN_PASS=change-me-admin-pass
RABBITMQ_PUBLISHER_USER=moscraper_publisher
RABBITMQ_PUBLISHER_PASS=change-me-publisher-pass
RABBITMQ_CRM_USER=moscraper_crm
RABBITMQ_CRM_PASS=change-me-crm-pass
# For publisher started on this laptop (outside docker).
RABBITMQ_URL=amqp://moscraper_publisher:change-me-publisher-pass@localhost:5672/moscraper
# Optional explicit CRM consumer URL for smoke/tests. Leave empty in local mode; in
# CloudAMQP shared/free mode set this to the provider AMQPS URL (often the same
# credential pair for both producer and CRM).
RABBITMQ_CRM_URL=
# For scripts/bootstrap_rabbitmq.py on this laptop.
RABBITMQ_MANAGEMENT_URL=http://127.0.0.1:15672
# For services started via docker-compose (rabbit host inside compose network).
RABBITMQ_DOCKER_URL=amqp://moscraper_publisher:change-me-publisher-pass@rabbitmq:5672/moscraper
# Share these LAN values with CRM laptop consumer.
RABBITMQ_LAN_HOST=CHANGE_ME_TO_YOUR_LAN_IP
RABBITMQ_CRM_URL_TEMPLATE=amqp://moscraper_crm:change-me-crm-pass@CHANGE_ME_TO_YOUR_LAN_IP:5672/moscraper
RABBITMQ_MANAGEMENT_BIND_HOST=127.0.0.1
RABBITMQ_AMQP_BIND_HOST=0.0.0.0
RABBITMQ_EXCHANGE=moscraper.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_QUEUE=scraper.products.v1
RABBITMQ_CRM_QUEUE=crm.products.import.v1
RABBITMQ_RETRY_EXCHANGE=crm.products.retry
RABBITMQ_REQUEUE_EXCHANGE=crm.products.requeue
RABBITMQ_DLX_EXCHANGE=crm.products.dlx
RABBITMQ_ROUTING_KEY=listing.scraped.v1
RABBITMQ_PUBLISH_MANDATORY=true
RABBITMQ_DECLARE_TOPOLOGY=false
RABBITMQ_HEARTBEAT_SECONDS=30
RABBITMQ_CONNECTION_NAME=publisher-service
RABBITMQ_RETRY_30S_MS=30000
RABBITMQ_RETRY_5M_MS=300000
RABBITMQ_RETRY_30M_MS=1800000
# Temporary migration helper for old local Rabbit volumes with incompatible queue args.
RABBITMQ_BOOTSTRAP_RECREATE_MISMATCHED_QUEUES=false
# Hosted shared/free brokers such as CloudAMQP Little Lemur usually do not let you
# create vhosts/users/permissions. Set these to false there and keep them true for the
# fully-managed local Docker broker or dedicated RabbitMQ.
RABBITMQ_BOOTSTRAP_MANAGE_VHOST=true
RABBITMQ_BOOTSTRAP_MANAGE_USERS=true
RABBITMQ_BOOTSTRAP_MANAGE_PERMISSIONS=true
MAX_PUBLISH_RETRIES=0

# Example shared/free hosted RabbitMQ profile:
# RABBITMQ_VHOST=provider-vhost
# RABBITMQ_ADMIN_USER=provider-user
# RABBITMQ_ADMIN_PASS=provider-pass
# RABBITMQ_PUBLISHER_USER=provider-user
# RABBITMQ_PUBLISHER_PASS=provider-pass
# RABBITMQ_CRM_USER=provider-user
# RABBITMQ_CRM_PASS=provider-pass
# RABBITMQ_URL=amqps://provider-user:provider-pass@provider-host/provider-vhost
# RABBITMQ_CRM_URL=amqps://provider-user:provider-pass@provider-host/provider-vhost
# RABBITMQ_MANAGEMENT_URL=https://provider-host
# RABBITMQ_BOOTSTRAP_MANAGE_VHOST=false
# RABBITMQ_BOOTSTRAP_MANAGE_USERS=false
# RABBITMQ_BOOTSTRAP_MANAGE_PERMISSIONS=false

# --- Scraper DB / outbox / publisher ---
SCRAPER_DB_PATH=data/scraper/scraper.db
SCRAPER_DB_BUSY_TIMEOUT_MS=5000
SCRAPER_DB_ENABLE_WAL=true
SCRAPER_OUTBOX_EVENT_TYPE=scraper.product.scraped.v1
SCRAPER_OUTBOX_BATCH_SIZE=50
SCRAPER_OUTBOX_LEASE_SECONDS=60
SCRAPER_OUTBOX_MAX_RETRIES=8
SCRAPER_OUTBOX_RETRY_BASE_SECONDS=15
PUBLISHER_POLL_INTERVAL_SECONDS=2.0
PUBLISHER_SERVICE_NAME=publisher-service

DEFAULT_CURRENCY=UZS
MESSAGE_SCHEMA_VERSION=1

# Parser → CRM lifecycle / identity (4A)
PARSER_LIFECYCLE_DEFAULT_EVENT=product_found
PARSER_ENABLE_RUNTIME_DELTA_EVENTS=false
PARSER_ALLOW_PRICE_CHANGED_WITH_RUNTIME_IDS=true
PARSER_ALLOW_OUT_OF_STOCK_WITH_RUNTIME_IDS=true
PARSER_ALLOW_CHARACTERISTIC_ADDED_WITH_RUNTIME_IDS=false
PARSER_FORCE_PRODUCT_FOUND_FALLBACK=true
PARSER_USE_CATALOG_FIND_PRECHECK=false

# Legacy delta flags (also required for runtime deltas)
PARSER_ENABLE_DELTA_EVENTS=false
PARSER_ENABLE_PRICE_CHANGED_EVENT=false
PARSER_ENABLE_OUT_OF_STOCK_EVENT=false
PARSER_ENABLE_CHARACTERISTIC_ADDED_EVENT=false

# --- Spec registry / extraction governance (3B) ---
ENABLE_STORE_SPEC_OVERRIDES=true
ENABLE_DEPRECATED_ALIAS_WARNINGS=true
ENABLE_SPEC_COVERAGE_REPORT=true
SPEC_MAPPING_MIN_COVERAGE_WARNING=0.35
CRM_INCLUDE_SPEC_COVERAGE=true

# Typed spec confidence / CRM operational metadata (3C)
ENABLE_TYPED_SPEC_CONFIDENCE=true
ENABLE_TYPED_SPEC_SUPPRESSION=true
TYPED_SPEC_MIN_CONFIDENCE_DEFAULT=0.65
TYPED_SPEC_MIN_CONFIDENCE_PHONE=0.70
TYPED_SPEC_MIN_CONFIDENCE_LAPTOP=0.70
TYPED_SPEC_MIN_CONFIDENCE_TV=0.60
TYPED_SPEC_MIN_CONFIDENCE_TABLET=0.70
TYPED_SPEC_MIN_CONFIDENCE_APPLIANCE=0.60
ENABLE_NORMALIZATION_QUALITY_SUMMARY=true
CRM_INCLUDE_FIELD_CONFIDENCE=true
CRM_INCLUDE_SUPPRESSED_TYPED_FIELDS=true
CRM_INCLUDE_NORMALIZATION_QUALITY=true

# Parser observability / ETL diagnostics (5A): structured logs + in-memory traces (no external APM)
ENABLE_STRUCTURED_SYNC_LOGS=true
ENABLE_IN_MEMORY_TRACE_BUFFER=true
TRACE_BUFFER_MAX_RECORDS=5000
ENABLE_BATCH_TRACE=true
ENABLE_HEALTH_SNAPSHOT=true
HEALTH_SNAPSHOT_INTERVAL_SECONDS=60
ENABLE_FAILURE_CLASSIFICATION=true
ENABLE_SYNC_CORRELATION_IDS=true
ENABLE_DIAGNOSTIC_PAYLOAD_SUMMARY=true
ENABLE_ETL_STATUS_EXPORT=true

# Parser SLO / operational policy (5B)
SLO_MIN_PARSE_SUCCESS_RATE=0.90
SLO_MIN_APPLY_SUCCESS_RATE=0.95
SLO_MAX_BLOCK_PAGE_RATE=0.10
SLO_MAX_ZERO_RESULT_CATEGORY_RATE=0.20
SLO_MAX_LOW_COVERAGE_RATE=0.35
SLO_MAX_REJECTED_ITEM_RATE=0.15
SLO_MAX_RETRYABLE_FAILURE_RATE=0.10
SLO_MAX_MALFORMED_RESPONSE_RATE=0.05
SLO_MAX_UNRESOLVED_RECONCILIATION_RATE=0.05
SLO_MAX_DUPLICATE_PAYLOAD_SKIP_RATE=0.50
SLO_MIN_ITEMS_PER_ACTIVE_STORE=20
INCIDENT_FAIL_RUN_ON_CRITICAL_GLOBAL_ALERT=false
INCIDENT_DISABLE_STORE_ON_CRITICAL_STORE_ALERT=false
ENABLE_OPERATIONAL_POLICY_LOGS=true

# Operator support / triage / runbooks (5C) — no external APM; JSON + logs only
ENABLE_OPERATOR_TRIAGE_SUMMARY=true
ENABLE_RUNBOOK_GENERATION=true
ENABLE_SAFE_REPLAY_SUPPORT=true
ENABLE_DIAGNOSTIC_SNAPSHOTS=true
ENABLE_STORE_DISABLE_ADVICE=true
SAFE_REPLAY_ALLOW_PRODUCT_FOUND=true
SAFE_REPLAY_ALLOW_DELTA_EVENTS=false
# Prefer *_PER_ACTION; SAFE_REPLAY_MAX_ITEMS / SAFE_REPLAY_MAX_BATCHES still accepted as aliases.
SAFE_REPLAY_MAX_ITEMS_PER_ACTION=20
SAFE_REPLAY_MAX_BATCHES_PER_ACTION=3
SAFE_REPLAY_REQUIRE_PRODUCT_FOUND_ONLY=true
DIAGNOSTIC_ERROR_SAMPLE_SIZE=20

# Release quality structured logs (6A); enable for release dry-runs
ENABLE_RELEASE_QUALITY_LOGS=false

# Contract evolution / parser→CRM compatibility (6C)
CONTRACT_SCHEMA_VERSION=v1
ENABLE_DUAL_SHAPE_OUTPUTS=false
ENABLE_SHADOW_FIELDS=true
ENABLE_DEPRECATION_WARNINGS=true
ENABLE_MIGRATION_READINESS_REPORT=true
ALLOW_BREAKING_CHANGES_WITHOUT_GATE=false
DEFAULT_DEPRECATION_STAGE=deprecated
ENABLE_COMPATIBILITY_GUARDS=true

# Rollout / feature flags (6B) — progressive enablement, no external flag SaaS
ENABLE_FEATURE_FLAGS=true
ENABLE_STORE_ROLLOUT_POLICY=true
ENABLE_CANARY_ROLLOUT=true
ENABLE_PROGRESSIVE_STORE_ENABLEMENT=true
ROLLOUT_DEFAULT_STAGE=disabled
ROLLOUT_CANARY_PERCENTAGE=10
ROLLOUT_PARTIAL_PERCENTAGE=30
ROLLOUT_HASH_BASED_SELECTION=true
ENABLE_AUTO_ROLLBACK_ADVICE=true
ENABLE_ROLLOUT_GUARD_BY_STATUS=true
ROLLOUT_BLOCK_ON_FAILING_STATUS=true
ROLLOUT_ALLOW_DEGRADED_CANARY=false

MOSCRAPER_DISABLE_PUBLISH=false

PROXY_LIST_PATH=
SENTRY_DSN=

SCRAPY_LOG_LEVEL=INFO
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=1.5
SCRAPY_HEADER_PROFILE_ROTATION_ENABLED=false
SCRAPY_RANDOMIZED_DELAY_ENABLED=false
SCRAPY_RANDOMIZED_DELAY_MIN_SECONDS=0.05
SCRAPY_RANDOMIZED_DELAY_MAX_SECONDS=0.35

# Crawl framework (2A): pagination guards + in-memory dedupe registry size
SCRAPY_MAX_PAGES_PER_CATEGORY=200
SCRAPY_MAX_EMPTY_LISTING_REPEATS=3
SCRAPY_MAX_DUPLICATE_LISTING_REPEATS=2
SCRAPY_LISTING_SIGNATURE_N=12
SCRAPY_CRAWL_REGISTRY_MAX_ENTRIES=50000

# Rotating proxy pool (optional). Requires readable PROXY_LIST_PATH.
SCRAPY_ROTATING_PROXY_ENABLED=false
SCRAPY_PROXY_POLICY_HARDENING_ENABLED=false
SCRAPY_PROXY_POLICY_DEFAULT_MODE=rotating
SCRAPY_PROXY_STICKY_REQUESTS_DEFAULT=20
SCRAPY_PROXY_COOLDOWN_SECONDS_DEFAULT=300
SCRAPY_PROXY_BAN_SCORE_THRESHOLD=3
SCRAPY_PROXY_MAX_CONSECUTIVE_FAILURES=2
SCRAPY_CAPTCHA_HOOKS_ENABLED=false
SCRAPY_CAPTCHA_SOLVER_BACKEND=noop
SCRAPY_CAPTCHA_MAX_SOLVE_ATTEMPTS=1
SCRAPY_CAPTCHA_SUSPICIOUS_REDIRECT_ENABLED=true
SCRAPY_HONEYPOT_FILTER_ENABLED=false
SCRAPY_HONEYPOT_FILTER_MAX_FILTER_RATIO=0.8
SCRAPY_BAN_SIGNAL_MONITORING_ENABLED=false
SCRAPY_BAN_SPIKE_WINDOW_SECONDS=120
SCRAPY_BAN_SPIKE_THRESHOLD=5
SCRAPY_EXPLICIT_BACKOFF_ENABLED=false
SCRAPY_EXPLICIT_BACKOFF_ENFORCE=false
SCRAPY_EXPLICIT_BACKOFF_ENFORCE_STORES=[]
SCRAPY_RATE_LIMIT_HEADER_INTELLIGENCE_ENABLED=true
SCRAPY_BACKOFF_BASE_SECONDS=1.0
SCRAPY_BACKOFF_MAX_SECONDS=90.0
SCRAPY_BACKOFF_COOLDOWN_MAX_SECONDS=300.0
SCRAPY_BACKOFF_RESPECT_RETRY_AFTER=true
SCRAPY_BACKOFF_429_STRICT=true
SCRAPY_RESOURCE_GOV_BYPASS_STORES=[]

STORE_NAMES=["mediapark", "texnomart", "uzum", "alifshop"]

# --- Local developer experience (9B) ---
# Active local crawl: keep TRANSPORT_TYPE=disabled; spiders write into scraper DB and outbox.
# Local publish: `python -m services.publisher.main --once`.
DEV_MODE=false
DEV_RUN_MODE=normal
DEV_DRY_RUN_DISABLE_CRM_SEND=true
DEV_ENABLE_DEBUG_SUMMARIES=true
DEV_ENABLE_SINGLE_STORE_MODE=true
DEV_ENABLE_FIXTURE_REPLAY=true
DEV_ENABLE_VERBOSE_STAGE_OUTPUT=false
DEV_DEBUG_MAX_ITEMS=20
DEV_DEBUG_INCLUDE_RAW_SPECS=true
DEV_DEBUG_INCLUDE_TYPED_SPECS=true
DEV_DEBUG_INCLUDE_LIFECYCLE=true
DEV_DEBUG_INCLUDE_APPLY_RESULTS=true
