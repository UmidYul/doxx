# =============================================================================
# UZ Tech Scraper — Environment Variables
# Скопируй в .env и заполни нужные значения
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
# Прямое подключение иногда только IPv6 — на Windows Python может не резолвить db.*.
# Тогда используй Session pooler из Dashboard → Connect → Session mode.
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
DATABASE_URL_SYNC=

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM fallback (опционально) ---
ANTHROPIC_API_KEY=
LLM_EXTRACTION_ENABLED=false
LLM_CACHE_TTL_DAYS=30

# --- Images (in-memory CLIP/rembg; no Supabase Storage) ---
REMBG_CONFIDENCE_THRESHOLD=0.7
MAX_IMAGES_PER_PRODUCT=5

# --- CRM API ---
CRM_API_URL=http://crm-service/api
CRM_API_KEY=secret-parser-key

# --- Proxies ---
PROXY_LIST_PATH=

# --- Мониторинг ---
SENTRY_DSN=

# --- Пороги ---
SPEC_SCORE_THRESHOLD_STRUCTURED=0.7
SPEC_SCORE_THRESHOLD_REGEX=0.4

# --- Scrapy ---
SCRAPY_LOG_LEVEL=INFO
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=1.5
