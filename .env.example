# Copy to .env — loaded by pydantic-settings (config/settings.py).
# Stack: RabbitMQ broker + Scrapy only. No application database or CRM HTTP client in this service.

APP_ENV=development
LOG_LEVEL=INFO

# --- RabbitMQ (required for live publish) ---
BROKER_TYPE=rabbitmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
# Topic exchange name (some docs call this EXCHANGE)
RABBITMQ_EXCHANGE=moscraper.events
RABBITMQ_EXCHANGE_TYPE=topic
RABBITMQ_ROUTING_KEY=listing.scraped.v1
# If no queue is bound yet (ingestion on CRM side), mandatory publish can fail — use false for local smoke tests.
RABBITMQ_PUBLISH_MANDATORY=true
# Scraper-side publish retries (0 = fail immediately; prefer CRM/broker consumer retries).
MAX_PUBLISH_RETRIES=0

DEFAULT_CURRENCY=UZS
MESSAGE_SCHEMA_VERSION=1

# Unit tests only — do not use in production
MOSCRAPER_DISABLE_PUBLISH=false

# Optional observability / scraping
PROXY_LIST_PATH=
SENTRY_DSN=

SCRAPY_LOG_LEVEL=INFO
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=1.5

# JSON array of store slugs (pydantic-settings). Optional; defaults to ["mediapark"] in code.
STORE_NAMES=["mediapark"]
