# =============================================================================
# UZ Tech Scraper — Environment Variables
# Скопируй в .env и заполни нужные значения
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://scraper:scraper@localhost:5432/uz_scraper
DATABASE_URL_SYNC=postgresql://scraper:scraper@localhost:5432/uz_scraper

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- LLM fallback (опционально — только для Узум и сложных описаний) ---
ANTHROPIC_API_KEY=
LLM_EXTRACTION_ENABLED=false
LLM_CACHE_TTL_DAYS=30

# --- Images ---
IMAGES_STORE=./data/images
REMBG_CONFIDENCE_THRESHOLD=0.7
MAX_IMAGES_PER_PRODUCT=5

# --- Proxies (опционально) ---
# Путь к файлу со списком прокси, по одному на строку: http://user:pass@host:port
PROXY_LIST_PATH=

# --- Мониторинг ---
SENTRY_DSN=

# --- Пороги извлечения характеристик ---
SPEC_SCORE_THRESHOLD_STRUCTURED=0.7
SPEC_SCORE_THRESHOLD_REGEX=0.4

# --- Scrapy ---
SCRAPY_LOG_LEVEL=INFO
SCRAPY_CONCURRENT_REQUESTS=8
SCRAPY_DOWNLOAD_DELAY=1.5
